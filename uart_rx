timescale 1ns / 1ps
module uart_receiver #(
    parameter CLOCK_FREQ = 50000000,  
    parameter BAUD_RATE = 9600         
)(
    input wire clk,                    
    input wire reset,                  
    input wire rx_line,                
    output reg [7:0] received_data,   
    output reg data_ready              
);
    localparam integer CYCLES_PER_BIT = CLOCK_FREQ / BAUD_RATE;
    localparam integer MID_BIT = CYCLES_PER_BIT / 2;
    
        localparam STATE_IDLE  = 3'b000;
        localparam STATE_START_BIT  = 3'b001;     
        localparam STATE_READ_BITS = 3'b010;   
        localparam STATE_STOP_BIT = 3'b011;   
        localparam STATE_DONE  = 3'b100;    
              
    reg [2:0] current_state = STATE_IDLE;

    reg [15:0] clock_counter = 0;
    reg [2:0] bit_counter = 0;
    reg [7:0] data_shift = 0;

    always @(posedge clk or posedge reset) begin
        if (reset) begin
            current_state <= STATE_IDLE;
            received_data <= 0;
            data_ready <= 0;
            clock_counter <= 0;
            bit_counter <= 0;
            data_shift <= 0;
        end else begin
            case (current_state)

                STATE_IDLE: begin
                    data_ready <= 0;
                    clock_counter <= 0;
                    bit_counter <= 0;

                    if (rx_line == 0)  
                        current_state <= STATE_START_BIT;
                end

                STATE_START_BIT: begin
                    if (clock_counter == MID_BIT) begin
                        if (rx_line == 0) begin
                            clock_counter <= 0;
                            current_state <= STATE_READ_BITS;
                        end else
                            current_state <= STATE_IDLE;  
                    end else begin
                        clock_counter <= clock_counter + 1;
                    end
                end

                STATE_READ_BITS: begin
                    if (clock_counter == CYCLES_PER_BIT - 1) begin
                        clock_counter <= 0;
                        data_shift[bit_counter] <= rx_line;

                        if (bit_counter == 7)
                            current_state <= STATE_STOP_BIT;
                        else
                            bit_counter <= bit_counter + 1;
                    end else begin
                        clock_counter <= clock_counter + 1;
                    end
                end
                STATE_STOP_BIT: begin
                    if (clock_counter == CYCLES_PER_BIT - 1) begin
                        received_data <= data_shift;
                        data_ready <= 1;   
                        clock_counter <= 0;
                        current_state <= STATE_DONE;
                    end else begin
                        clock_counter <= clock_counter + 1;
                    end
                end

                STATE_DONE: begin
                    data_ready <= 0;
                    current_state <= STATE_IDLE;
                end

                default: current_state <= STATE_IDLE;
            endcase
        end
    end

endmodule
